pipeline {

    agent any

    environment {
        CLUSTER_NAME = 'shopwave-cluster'
        NAMESPACE = 'shopwave'
        BACKEND_IMAGE = 'ecommerce-web-backend:latest'
        FRONTEND_IMAGE = 'ecommerce-web-frontend:latest'
    }

    stages {

        stage('Clone Code') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/Ritishhire/web-ecommerce-jenkins-k8s.git'
            }
        }

        stage('Build Docker Images') {
            steps {
                sh '''
                    docker build -t $BACKEND_IMAGE ./backend
                    docker build -t $FRONTEND_IMAGE ./frontend
                '''
            }
        }

        stage('Create Kubernetes Cluster') {
            steps {
                sh '''
                    if kind get clusters | grep -q "^$CLUSTER_NAME$"; then
                      echo "Cluster already exists"
                    else
                      kind create cluster --config k8s/kind-cluster.yaml
                    fi

                    kubectl config use-context kind-$CLUSTER_NAME
                '''
            }
        }

        stage('Deploy To Kubernetes') {
            steps {
                sh '''
                    kind load docker-image $BACKEND_IMAGE --name $CLUSTER_NAME
                    kind load docker-image $FRONTEND_IMAGE --name $CLUSTER_NAME

                    kubectl apply -k k8s

                    kubectl -n $NAMESPACE rollout restart deployment/backend
                    kubectl -n $NAMESPACE rollout restart deployment/frontend

                    kubectl -n $NAMESPACE rollout status statefulset/mongo
                    kubectl -n $NAMESPACE rollout status deployment/backend
                    kubectl -n $NAMESPACE rollout status deployment/frontend
                '''
            }
        }

        stage('Seed Database') {
            steps {
                sh '''
                    kubectl -n $NAMESPACE exec deployment/backend -- npm run seed
                '''
            }
        }
    }

    post {
        success {
            echo 'Deployment completed successfully'
            echo 'Frontend URL: http://127.0.0.1:30080'
        }

        failure {
            echo 'Pipeline failed'
        }
    }
}
